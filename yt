#!/bin/bash

# Ensure dependencies are installed
if ! command -v dialog &> /dev/null; then pkg install dialog -y; fi

URL="$1"
[ -z "$URL" ] && URL=$(dialog --title "YT Manager" --inputbox "Paste URL:" 8 60 3>&1 1>&2 2>&3)
[ -z "$URL" ] && exit 1

# Menu Selection
CHOICE=$(dialog --clear --title "Format" --menu "Choose:" 12 50 4 \
"1" "MP4 Video" \
"2" "MKV Video" \
"3" "MP3 Audio" 3>&1 1>&2 2>&3)

if [ "$CHOICE" == "3" ]; then
    OPTS="-x --audio-format mp3 --audio-quality 0"
    OUT="music/%(playlist_title|Unknown)s/%(title)s.%(ext)s"
else
    RES=$(dialog --title "Quality" --menu "Max Height:" 12 50 4 \
    "2160" "4K" "1080" "1080p" "720" "720p" "480" "480p" 3>&1 1>&2 2>&3)
    [ -z "$RES" ] && RES="1080"
    
    EXT="mp4"; [ "$CHOICE" == "2" ] && EXT="mkv"
    OUT="yt/%(uploader)s/%(playlist_title|)s/%(title)s + ${RES}p.%(ext)s"
    
    # CRITICAL: Quotes around the format string
    OPTS="-f bv[height<=${RES}]+ba/b[height<=${RES}]/b --merge-output-format $EXT"
fi

# Run it
yt-dlp --sleep-requests 2 --add-metadata $OPTS -o "$OUT" "$URL"