#!/bin/bash

URL="$1"

if [ -z "$URL" ]; then
    read -p "🔗 Paste YouTube URL: " URL
    [ -z "$URL" ] && { echo "❌ No URL provided."; exit 1; }
fi

echo "==============================="
echo "       YT MANAGER"
echo "==============================="
echo "[1] Video"
echo "[2] Audio"
echo "-------------------------------"
read -p "👉 Choose type (1/2): " TYPE

COMMON="--embed-metadata --no-warnings"

if [ "$TYPE" == "2" ]; then
    # Audio Setup
    OPTS="-x --audio-format mp3 --audio-quality 0"
    OUT="music/%(uploader)s/%(playlist_title|Singles)s/%(title)s.%(ext)s"
else
    # Video Setup
    read -p "👉 Max Resolution (e.g., 1080, 720) [Default 1080]: " RES
    [ -z "$RES" ] && RES="1080"
    
    # FIX: No more escaped quotes here!
    OPTS="-S res:${RES} --merge-output-format mkv"
    OUT="yt/%(uploader)s/%(playlist_title|Singles)s/%(title)s_[${RES}p].%(ext)s"
fi

echo "🚀 Starting download... (Extracting info and finding best formats)"

yt-dlp $COMMON $OPTS -o "$OUT" "$URL"

echo "✅ Task Finished!"