#!/bin/bash

URL="$1"

# 1. Ask for URL if not provided via command line
if [ -z "$URL" ]; then
    read -p "Paste YouTube URL: " URL
    [ -z "$URL" ] && { echo "No URL provided. Exiting."; exit 1; }
fi

# 2. Simple Text Menu
echo "==============================="
echo "       YT MANAGER"
echo "==============================="
echo "[1] MP4 (Video)"
echo "[2] MKV (Video + Subs)"
echo "[3] MP3 (Audio Only)"
echo "-------------------------------"
read -p "👉 Choose format (1/2/3): " CHOICE

if [ "$CHOICE" == "3" ]; then
    EXT="mp3"
    OUT="music/%(playlist_title|Unknown)s/%(title)s.%(ext)s"
    OPTS="-x --audio-format mp3 --audio-quality 0"
else
    echo "-------------------------------"
    echo "Common qualities: 2160, 1080, 720, 480"
    read -p "👉 Enter Max Resolution (default 1080): " RES
    
    # Default to 1080 if you just hit Enter
    [ -z "$RES" ] && RES="1080"
    
    EXT="mp4"; [ "$CHOICE" == "2" ] && EXT="mkv"
    OUT="yt/%(uploader)s/%(playlist_title|)s/%(title)s + ${RES}p.%(ext)s"
    
    # CRITICAL FIX: Double quotes around the format string
    OPTS="-f \"bv[height<=${RES}]+ba/b[height<=${RES}]/b\" --merge-output-format $EXT"
fi

echo "Starting download..."

# 3. Execute yt-dlp
yt-dlp --sleep-requests 2 --add-metadata $OPTS -o "$OUT" "$URL"

echo "Task Finished!"
